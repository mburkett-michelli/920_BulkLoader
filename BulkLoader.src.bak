handler Timer1Trip;     -- Clear Auger Message
--Declaration Section

begin
    
    DisplayStatus("");
    return;

end;                     



handler Timer2Trip; ----Finish Batch Gates Closed Settle Scale
--Declaration Section

begin

    SetDigout(2,2,0);
    SetDigout(2,3,0);
    SetTimerMode(3,TimerOneShot);
    SetTimer(3,100);
    StartTimer(3);
    SetLabelText(Lbl15S1,"Scale Settling");
    return;

end;                



handler Timer3Trip;    --Batch Finished Read Weight
--Declaration Section
CurWt : real;
MinWt : real;
begin
    
    GetGross(1,Primary,CurWt);
    --GetSPValue(14,MinWt);
    if CurWt>g_EmptyScale then
    
        SetTimerMode(4,TimerOneShot);--Open Dump Gate
        SetDigout(2,3,1);
        SetLabelText(Lbl15S1,"Product Still in Scale - Dumping");              
        SetTimer(4,300);                                  
        StartTimer(4);
      
    else
        Batch_Is_Done;
    end if;
    return;

end;  



handler Timer4Trip;--Finished Batch Close Dump Off
--Declaration Section

begin
      
      SetTimerMode(5,TimerContinuous);--Check For Weight
      SetTimerMode(6,TimerOneShot);--Give Up Took To Long
      SetTimer(5,100);
      SetTimer(6,600);
      StartTimer(5);
      StartTimer(6);
      
    return;

end;


handler Timer5Trip;
--Declaration Section
CurWt : real;
MinWt : real;
begin
    --SetDigout(2,4,0);
    GetGross(1,Primary,CurWt);
    --GetSPValue(14,MinWt);
    SetLabelText(Lbl15S1,"Reading Weight");                  
    if CurWt<=MinWt then
        StopTimer(5);
        StopTimer(6);
    
        Batch_Is_Done;
    end if;     

    return;

end;

handler Timer6Trip;
--Declaration Section
CurWt : real;
MinWt : real;
begin 
    
    StopTimer(6);
    StopTimer(5);
    Batch_Is_Done;
    
    return;

end;

handler Timer7Trip;   -- BarGraph Update
-- Declaration Section
BLevel  :   integer;
BLevel1 :   integer;
CurWt   :   real;
BTotal  :   real;

begin
    
    --Calculate Levels
    GetGross(1,Primary,CurWt);
    -- Protect from divide by zero
    if CurWt<1 then
        CurWt:=1;
    end if;
    BLevel:=(CurWt/g_DraftTarget)*100;
    if BLevel > 100 then
        BLevel:=100;
    end if;
    -- Protect from divide by zero
    if g_BatchedSoFar<1 then
        BTotal:=1;
    else
        BTotal:=g_BatchedSoFar;
    end if;
    BLevel1:=(BTotal/g_BatchTarget)*100;
    if BLevel1 > 100 then
        BLevel1:=100;
    end if;
    
    --Update BarGraphs
    SetBargraphLevel(Bar1S1,BLevel);
    SetBargraphLevel(Bar2s1,BLevel1);
    
    return;
    
end;




handler Timer10Trip;
--Declaration Section

begin
    
    SetDigout(2,3,0);
    SetTimerMode(11,TimerOneShot);
    SetTimer(11,100);
    StartTimer(11);    
    return;

end;

handler Timer11Trip;
--Declaration Section

begin

    RunBatch;
    return;

end;

handler Timer12Trip;
-- Declaration Section

begin

-- Use a g_Scalecheck = 9 to trap exiting back to main menu
    
    if g_Startup = 0 then -- Indicator Startup Clear First Status Window
        SetLabelText(lbl5s9,"");
        DisplayStatus("");
        
        -- Removed Commodities because of issues that need to be worked out.
        
        --g_Startup:=1;
        --Load_Commodities;
        
        -- So jump straight to main menu
        g_Startup:=2;
        MainScreen;
    elsif g_Startup = 1 then
        SetLabelText(lbl5s9,"");
        DisplayStatus("");
        g_Startup:=2;
        MainScreen;
    elsif g_Startup = 10 then
        SetLabelText(lbl9s3,"");
        DisplayStatus("");
        if g_ScaleCheck = 9 then
            g_Startup:=2;
            MainScreen;
        else
            g_ScaleCheck:=0;
            Display_Setup;
        end if;
    else
        SetLabelText(lbl15s1,"");
        DisplayStatus("");
    end if;
    return;
    
end;

handler Timer13Trip;     -- Scale Check Timer
-- Declaration Section

begin

    if g_Startup = 4 then
    
        if g_ScaleCheck = 0 then
            g_ScaleCheck:=1;
        elsif g_ScaleCheck = 2 then
            g_ScaleCheck:=3;
        end if;    
    
    end if;        
    
    return;
    
end;

handler Userentry;
--Declaration Section
UserString : string;
UserValue : real;
DbStatus : SysCode;
DisplayPrompt : string;      
Ticket : real;
begin     
    
    UserString := GetEntry;
    ClosePrompt;  
    EnableHandler(Numerickeypressed);
    
    if EventKey = EnterKey  then                             
        
        if g_Startup = 0 then
        
            SetLabelText(lbl5s9,"");
            DisplayStatus("");
            g_Startup:=1;
            Load_Commodities;
        
        elsif g_Startup = 1 then
            
            SetLabelText(lbl5s9,"");
            DisplayStatus("");
            g_Startup:=2;
            MainScreen;
                
        elsif g_Startup = 7 or g_Startup = 12 then
            -- Exit From Quick Entry Clause
            if UserString = "999" then
            
                g_Startup:=2;
                g_ScaleCheck:=0;
                g_TranCarNumber:="";
                g_TranCommodity:="";
                g_PreActTarget:=0;
                g_BatchTarget:=0;
                g_DraftTarget:=0;
                            
                MainScreen;
            
            elsif g_ScaleCheck = 0 or g_ScaleCheck = 11 then
        
                g_TranCarNumber:=UserString;
                SetLabelText(lbl11s3,UserString);
                -- Skip Commodity and preact for that commodity
                -- g_ScaleCheck:=1;
                -- DisplayStatus("Enter Commodity:");
                if g_ScaleCheck = 0 then
                    if g_Startup = 12 then
                        g_ScaleCheck:=3;
                        DisplayStatus("Enter Batch Amount:");
                    else
                        g_ScaleCheck:=2;
                        DisplayStatus("Enter Early Cut Off");
                    end if;
                    PromptUser("=>");
                end if;    
            elsif g_ScaleCheck = 1 then   -- Not currently used
            
                g_TranCommodity:=UserString;
                SetLabelText(lbl6s1,UserString);
                g_ScaleCheck:=2;
                DisplayStatus("Enter Early Cut Off");
                PromptUser("Amount=>");
                
            elsif g_ScaleCheck = 2 then
                
                UserValue:=StringToReal(UserString);
                if UserValue<=0 then
                    g_PreActTarget:=g_PreAct;
                else               
                    g_PreActTarget:=UserValue;
                    g_ScaleCheck:=3;
                    DisplayStatus("Enter Batch Amount:");
                    PromptUser("=>");
                end if;
                
            elsif g_ScaleCheck = 3 or g_ScaleCheck = 12 then
                UserValue:=StringToReal(UserString);
                if UserValue<=0 then
                    DisplayStatus("Must Be > 0");
                    PromptUser("Amount=>");  
                else               
                    g_BatchTarget:=UserValue;
                    SetLabelText(lbl12s3,UserString);
                    if g_ScaleCheck = 3 then
                        g_ScaleCheck:=4;
                        DisplayStatus("Enter Draft Amount:");
                        PromptUser("=>");  
                    end if;
                end if;
                
            elsif g_ScaleCheck = 4 or g_ScaleCheck = 13 then
                UserValue:=StringToReal(UserString);
                if UserValue<=0 then
                    DisplayStatus("Must Be > 0");
                    PromptUser("Amount=>");  
                else               
                    g_DraftTarget:=UserValue;
                    SetLabelText(lbl13s3,UserString);
                    if g_ScaleCheck = 4 then
                        g_ScaleCheck:=5;
                        if g_Startup = 7 then
                            DisplayStatus("Press 'Enter' To Start");
                        else
                            DisplayStatus("Press 'Enter' to Save");
                        end if;
                        PromptUser("=>");
                    end if;
                end if;
                
            elsif g_ScaleCheck = 5 then
                
                if g_Startup = 7 then
                    
                    SetLabelText(lbl22s1,g_TranCarNumber);
                    SetLabelText(lbl1s1,RealToString(g_BatchTarget,6,0));
                    SetLabelText(lbl16s1,RealToString(g_DraftTarget,4,0));
                    g_PreAct:=g_PreActTarget;
                    Check_Motion;
                    
                else
                    
                    Save_Job;
                    
                end if;
                    
            end if;
        
        elsif g_Startup = 10 then    -- Coming from Setup Menu
        
            ConfigEntryCheck(UserString);
                
        end if;               
    end if;
        
    return;

end;


     
handler User1Keypressed;    -- Start Batching
--Declaration Section

begin               
    
    if g_BatchStatus=Idle then
        
        if g_Startup = 4 then
            
            if g_ScaleCheck = 3 then
                g_ScaleCheck:=0;
                CheckForZero;
            end if;
                
        elsif g_Startup = 2 then
            
            if g_CurrentJob = 0 then
                g_Startup:=11;
                DisplayJobs;
            else
                Check_Motion;
            end if;
            --SetLabelText(lbl15s1,"Currently Disabled.");
            
        elsif g_Startup = 5 then
            
            Start_Batching;
            
        elsif g_Startup = 12 then
            
            --if g_NumberofJobs < 5 then
                JobScreen;
                g_ScaleCheck:=0;
                SetLabelText(lbl9s3,"Press '999' to Abort and Start Over");
                DisplayStatus("Enter Car ID:");
                PromptUser("=>");
            --end if;           
        end if;
    
    else
        
        StopBatch;
        ResetBatch;
        FinishBatch;    
            
    end if;    
    return;

end;


handler User2Keypressed;    -- Pause or Stop Batching
--Declaration Section
CheckBatch  :   BatchStatus;

begin

    if g_BatchStatus=Idle then
    
        if g_Startup = 4 then
        
            g_Startup:=2;
            MainScreen;
        
        elsif g_Startup = 10 then
        
            Save_Config;
            
        elsif g_Startup = 12 then
            
            g_ScaleCheck:=11;
            JobScreen;
            EditaJob;
            
        end if;
    
    elsif g_BatchStatus = Batching then
    
        if g_Startup = 5 then
                             
            GetBatchStatus(CheckBatch);
            if CheckBatch=BatchRunning then
                PauseBatch;
            
                MainScreen;
            else
            
                SetLabelText(lbl15s1,"Batch does not show BatchRunning");
                StartTimer(12); 
            
            end if;
        end if;
            
    end if;    
          
--    StopBatch;
    --ResetBatch;
--    g_BatchStatus:=Idle;
--    MainScreen;
    return;

end;

handler User3Keypressed;  -- Jobs Menu
--Declaration Section

begin
    
    if g_Startup = 2 then
    
        g_Startup:=12;
        DisplayJobs;
    
    elsif g_Startup = 12 then
    
        DeleteJob;
        DisplayJobs;
            
    end if;
    return;

end;


handler User4Keypressed; -- Quick Fill Entry
--Declaration Section

begin
    
    JobScreen;
    g_Startup:=7;
    g_ScaleCheck:=0;
    SetLabelText(lbl9s3,"Press '999' to Abort and Start Over");
    DisplayStatus("Enter Car ID:");
    PromptUser("=>");
    return;

end;

handler User5keypressed;   -- Setup Menu
--Declaration Section

begin

    if g_Startup = 2 then
        g_Startup:=10;
        g_ScaleCheck:=0;
        Display_Setup;
    
    elsif g_Startup = 11 or g_Startup = 12 then     -- returning from jobs menu
        
        if g_ScaleCheck = 0 then
            g_Startup:=2;
            MainScreen;
        else
            Save_Job;
            g_ScaleCheck:=0;
            DisplayJobs;
        end if;
    end if;

    return;
    
end;


handler Navupkeypressed;
--Declaration Section

begin
    
    if g_Startup = 12 then
    
        if g_iUserSelection > g_iScreenPosition then
            g_iUserSelection:=g_iUserSelection-1;
        else
            if g_iScreenPosition > 1 then    -- If not on first screen
                g_iScreenPosition:=g_iScreenPosition - 5;  --Go Back a screen
                if g_iScreenPosition < 1 then -- If that is too far reset to first screen
                    g_iScreenPosition:=1;
                end if;
                g_iUserSelection:=g_iScreenPosition;
            end if;
        end if;
        DisplayJobs;
    end if;
    return;

end;

handler Enterkeypressed;
--Declaration Section

begin
    
    if g_Startup = 11 then
        
        g_TranCarNumber:=g_CarNumber[g_iUserSelection];
        --    g_Commodity[CurrentPosition]:=""
        g_BatchTarget:=g_Target[g_iUserSelection];
        g_DraftTarget:=g_Draft[g_iUserSelection];
        SelectScreen(1);
        SetLabelText(lbl22s1,g_TranCarNumber);
        SetLabelText(lbl1s1,RealToString(g_BatchTarget,6,0));
        SetLabelText(lbl16s1,RealToString(g_DraftTarget,4,0));
        
        Check_Motion;
            
    end if;
    return;

end;


handler Navdownkeypressed;
--Declaration Section

begin
    
    if g_Startup = 12 then
        if g_iUserSelection < g_iScreenPosition+4 and g_iUserSelection < g_NumberofJobs then
            g_iUserSelection:=g_iUserSelection+1;
        else
            if g_iScreenPosition+5 < g_NumberofJobs+1 then    -- If not on last screen
                g_iScreenPosition:=g_iScreenPosition + 5;  --Go Forward a screen
                g_iUserSelection:=g_iScreenPosition;
            end if;    
            
        end if;
        DisplayJobs;
    end if;
    return;

end;

handler Navleftkeypressed;
--Declaration Section

begin
    
    if g_Startup = 12 then
        if g_iScreenPosition - 5 > 0 then
        
            g_iScreenPosition:=g_iScreenPosition - 5;
            g_iUserSelection:=g_iScreenPosition;
        
        else
        
            g_iScreenPosition:=1;
            
        end if;
        DisplayJobs;    
    end if;
    return;

end;

handler Navrightkeypressed;
--Declaration Section

begin

    if g_Startup = 12 then    
        if g_iScreenPosition +5 < g_NumberofJobs+1 then
        
            g_iScreenPosition:=g_iScreenPosition+5;
            g_iUserSelection:=g_iScreenPosition;
        
        end if;                                 
        DisplayJobs;
    end if;
    return;
    
end;


