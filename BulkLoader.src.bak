--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=1;
        DisplayStatus("Enter Default Draft");
        PromptUser("=>");
    
    end if;    
    return;

end;

handler N2Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=2;
        DisplayStatus("Enter Early CutOff");
        PromptUser("=>");
    
    elsif g_Startup = 12 and g_ScaleCheck>10 then
    
        g_ScaleCheck:=11;
        DisplayStatus("Enter Car ID:");
        PromptUser("=>");
        
    end if;    
    return;

end;


handler N3Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=3;
        
    elsif g_Startup = 12 then
    
        g_ScaleCheck:=12;
        DisplayStatus("Enter Batch Amt");
        PromptUser("=>");
        
    end if;    
    return;

end;


handler N4Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=4;
        DisplayStatus("Enter Min Draft");
        PromptUser("=>");
    
    elsif g_Startup = 12 then
    
        g_ScaleCheck:=13;
        DisplayStatus("Enter Draft Amt");
        PromptUser("=>");
        
    end if;    
    return;

end;


handler N5Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=5;
        DisplayStatus("Enter Max Draft:");
        PromptUser("=>");
    
    end if;    
    return;

end;

handler N6Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=6;
        DisplayStatus("Settling Time:");
        PromptUser("=>");
    
    end if;    
    return;

end;

handler N7Keypressed;
--Declaration Section

begin
    
    if g_Startup = 10 then
        
        g_ScaleCheck:=7;
        DisplayStatus("Empty Scale Level:");
        PromptUser("=>");
    
    end if;    
    return;

end;




       
-- End of event handlers.
----------------------------------------------------------------------------

   


------------------------------------------------------------------------------
-- This chunk of code is the system startup event handler.

begin

  -- Increment the build number every time you make a change and recompile.
    g_iBuild := 1; 
    -- Delay Timer to Update Main Screen Status
    SetTimerMode(7,TimerContinuous);
    SetTimer(7,30);
    SetTimerMode(12,TimerOneShot);
    SetTimer(12,300);
    SetTimerMode(13,TimerOneShot);
    SetTimer(13,300);

  -- Initialize all global variables here. 
    g_Startup:=0;
    SetLabelText(lbl15s1,""); 
    SetBargraphLevel(Bar1S1,1);
    SetBargraphLevel(Bar2s1,1);
  -- Load Database Values
    SelectScreen(9);
    Load_Config;
    -- Commodity Load is handled by the tripping of timer 12.

   

end  BulkLoader; 
-- This name must match the name following "program" keyword at 
-- the beginning of the program.

